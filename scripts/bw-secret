#!/usr/bin/env bash
# bw-secret — fetch a Bitwarden item from vault.ferreri.us, handling login
# and unlock idempotently. Intended for use inside llm-bawt bridge containers
# where BW_PASSWORD is injected via the compose env_file.
#
# usage:
#   bw-secret <name>                     # prints the password field
#   bw-secret <name> --field <field>     # prints a named custom field
#   bw-secret <name> --json              # prints the full item JSON
#   bw-secret --ensure-session           # prints `export BW_SESSION=...` for eval
#
# env:
#   BW_PASSWORD  (required) — master password for vex@ferreri.us
#   BW_USER      (optional) — defaults to vex@ferreri.us
#   BW_SESSION   (optional) — reused if already valid; otherwise we unlock
set -euo pipefail

: "${BW_PASSWORD:?BW_PASSWORD must be set (compose env_file should provide it)}"
: "${BW_USER:=vex@ferreri.us}"

log() { printf '[bw-secret] %s\n' "$*" >&2; }

ensure_logged_in() {
  local status
  status=$(bw status 2>/dev/null | jq -r '.status' 2>/dev/null || echo unauthenticated)
  if [ "$status" = "unauthenticated" ]; then
    log "logging in as $BW_USER"
    bw login "$BW_USER" --passwordenv BW_PASSWORD --raw >/dev/null
  fi
}

ensure_session() {
  # If BW_SESSION is set and the API accepts it, reuse it.
  if [ -n "${BW_SESSION:-}" ]; then
    if BW_SESSION="$BW_SESSION" bw status 2>/dev/null \
        | jq -e '.status == "unlocked"' >/dev/null; then
      return 0
    fi
    log "stale BW_SESSION, re-unlocking"
  fi
  BW_SESSION=$(bw unlock --passwordenv BW_PASSWORD --raw)
  export BW_SESSION
}

main() {
  ensure_logged_in

  # --ensure-session: emit shell-evalable session export and exit
  if [ "${1:-}" = "--ensure-session" ]; then
    ensure_session
    printf 'export BW_SESSION=%q\n' "$BW_SESSION"
    return 0
  fi

  local name="${1:?usage: bw-secret <name> [--field <f> | --json]}"; shift || true
  local mode=password field=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --field) mode=field; field="${2:?--field requires a name}"; shift 2 ;;
      --json)  mode=json; shift ;;
      *)       log "unknown arg: $1"; return 2 ;;
    esac
  done

  ensure_session
  case "$mode" in
    password) bw get password "$name" ;;
    json)     bw get item "$name" ;;
    field)
      bw get item "$name" \
        | jq -er --arg f "$field" '.fields[]? | select(.name==$f) | .value' \
        || { log "field '$field' not found on item '$name'"; return 1; }
      ;;
  esac
}

main "$@"
