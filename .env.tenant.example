# =============================================================================
# .env.tenant.example — the SINGLE SOURCE OF ENVIRONMENT TRUTH for a tenant.
#
# Copy to `.env` beside docker-compose.prod.yml and fill the marked values:
#     cp .env.tenant.example .env
#
# THE LAW (Self-Hosted Tenant project):  compute is a URL; data is ALWAYS local.
#   - DATA  (Postgres, Redis, media, NocoDB) runs INSIDE this tenant. The prod
#     compose wires all of it to in-stack services / named volumes for you, so
#     those knobs are intentionally absent below — you do not set them.
#   - COMPUTE (embeddings, TTS, STT) is GPU-bound and may be BORROWED from a
#     shared GPU host (echo) over HTTP/WS, or served locally if this tenant has
#     its own GPU. Those URLs are the ONLY references to anything outside this
#     tenant, and they are the only ones you must point somewhere.
#
# This file is the minimal tenant surface. The full knob catalog (host/dev
# deployments) lives in .env.docker — do not duplicate it here.
# =============================================================================

# --- SECRETS (generate; never commit real values) ----------------------------
# Postgres password for the in-stack DB. Generate once per tenant, e.g.:
#     openssl rand -hex 24
# The prod compose feeds this to BOTH the postgres container and the app.
LLM_BAWT_POSTGRES_PASSWORD=

# --- OPTIONAL COMPUTE ENDPOINTS (leave blank to boot without them) ------------
# Memory embeddings (CPU, MiniLM — NOT GPU). Optional: the stack boots without
# it; only memory/vector writes degrade until an embed service is present.
# Defaults to an in-stack service (http://local-model-bridge:8684) if you add
# one. Leave blank to run the tenant without memory embeddings for now.
LOCAL_MODEL_EMBED_URL=

# Voice (bawthub) — GPU, borrowed from a GPU host. Leave BLANK for now: this
# tenant does not need voice/GPU. Fill only when a GPU plane exists.
BAWTHUB_TTS_URL=
BAWTHUB_STT_URL=

# --- LLM PROVIDER KEYS (set the ones your default bots/models use) ------------
OPENAI_API_KEY=
XAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_BAWT_NEWSAPI_API_KEY=

# --- OPTIONAL OVERRIDES -------------------------------------------------------
# Published host ports (host -> container). Defaults shown.
# MCP_PORT=8001
# SERVICE_PORT=8642
#
# Image tags (default: latest). Pin to a digest/sha for reproducible tenants.
# IMAGE_TAG=latest
# FRONTEND_TAG=latest
#
# Storage backend. Default `fs` (local named volume) — self-sufficient.
# Only set `s3` if you run a TENANT-OWNED object store; never point it at
# another tenant's / echo's Garage. If s3: also set LLM_BAWT_S3_ENDPOINT,
# LLM_BAWT_S3_BUCKET, LLM_BAWT_S3_ACCESS_KEY, LLM_BAWT_S3_SECRET_KEY.
# LLM_BAWT_STORAGE_BACKEND=fs

# =============================================================================
# NOT SET HERE ON PURPOSE — the prod compose already wires these to LOCAL,
# in-stack services. Setting them by hand risks pointing a tenant at echo:
#   LLM_BAWT_POSTGRES_HOST / _PORT / _USER / _DATABASE  (-> in-stack `postgres`)
#   REDIS_URL                                           (-> in-stack `redis`)
#   LLM_BAWT_MEDIA_ROOT / MEDIA_STORAGE_PATH            (-> app-storage volume)
#   DATABASE_URL (frontend Prisma)                      (-> in-stack `postgres`)
# =============================================================================
