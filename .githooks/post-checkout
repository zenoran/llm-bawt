#!/bin/sh
# Loud warning when HEAD leaves the canonical branch.
#
# Git has no native pre-checkout hook, so we can't *block* the switch —
# but we can make it impossible to miss. Combined with pre-commit, the
# practical harm (committing on the wrong branch) is contained.
#
# Args from git: $1=prev-HEAD, $2=new-HEAD, $3=1 if branch checkout (else file checkout)

[ "$3" = "1" ] || exit 0   # file-level checkouts: ignore

canonical=$(git config branch.canonical 2>/dev/null || echo "master")
current=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

if [ "$current" != "$canonical" ]; then
    cat >&2 <<EOF

  ⚠️  WARNING: now on branch '$current' (canonical = '$canonical').

      Live containers see this repo's working tree.
      Stay here only as long as you need to. Commits here will be
      blocked by pre-commit unless you bypass with --no-verify.

EOF
fi

exit 0
