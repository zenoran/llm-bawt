# Lightweight bridge image — no CUDA/GPU, just Python + bridge deps
FROM python:3.12-slim

# Tools grouped by purpose (one group per line):
#   core:       curl libpq5 openssh-client git ca-certificates
#   data:       jq yq
#   search:     ripgrep fd-find
#   db clients: postgresql-client redis-tools sqlite3
#   sys/proc:   procps iproute2 less tree
#   net debug:  dnsutils iputils-ping netcat-openbsd
#   archives:   unzip zip xz-utils
#   build:      make
#   python pkg: pipx (used to install editable `llm` CLI for the bridge user)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl libpq5 openssh-client git ca-certificates \
    jq yq \
    ripgrep fd-find \
    postgresql-client redis-tools sqlite3 \
    procps iproute2 less tree \
    dnsutils iputils-ping netcat-openbsd \
    unzip zip xz-utils \
    make \
    pipx \
    && rm -rf /var/lib/apt/lists/* \
    && ln -s "$(which fdfind)" /usr/local/bin/fd

RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

WORKDIR /app

# Copy project metadata for dependency resolution
COPY pyproject.toml ./

# Copy the full src tree.
# Previously this only copied the three bridge packages, but the editable
# `llm` CLI (installed via pipx below) needs `llm_bawt` available too. The
# whole src/ is only ~6 MB — not worth the granular COPY complexity.
COPY src/ ./src/

# Minimal venv with only what bridges need
RUN uv venv && uv pip install \
    "redis[hiredis]>=5.0.0" \
    "sqlalchemy>=2.0" \
    "psycopg2-binary>=2.9" \
    "websockets>=13.0" \
    "httpx>=0.26.0" \
    "anyio>=4.0" \
    "claude-agent-sdk>=0.1.56" \
    "openai-codex-sdk>=0.1.11" \
    "pydantic>=2.0"

# Install project in editable mode so both bridge packages are importable
RUN uv pip install -e . --no-deps

RUN useradd -m -s /bin/bash bridge && chown -R bridge:bridge /app
# Pre-create ~/.codex so Docker bind mounts inherit bridge ownership for
# the parent directory; otherwise codex CLI can't write cache/log/history
# alongside the bind-mounted auth.json and config.toml.
RUN mkdir -p /home/bridge/.codex && chown bridge:bridge /home/bridge/.codex
USER bridge

# pipx-installed `llm` CLI (editable, full deps).
# Mirrors `make install` — gives the bridge user a working `llm` command
# in an isolated env at ~/.local/share/pipx/venvs/llm-bawt while keeping
# /app/.venv lean (bridge runtime deps only). Editable means changes to
# /app/src (bind-mounted in dev) are picked up without reinstall.
ENV PIPX_HOME=/home/bridge/.local/share/pipx \
    PIPX_BIN_DIR=/home/bridge/.local/bin
RUN pipx install --force --editable /app

# /home/bridge/.local/bin first so pipx `llm` shadows the dep-less stub
# in /app/.venv/bin. `python` still resolves to /app/.venv/bin/python,
# so `python -m openclaw_bridge` etc. continue to use the bridge venv.
ENV PATH="/home/bridge/.local/bin:/app/.venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    HOME=/home/bridge

# Default command — overridden per service in docker-compose.yml
CMD ["python", "-m", "openclaw_bridge"]
