# Docker environment template for llm-bawt.
# Copy this file to .env and fill in your real values.
# .env is gitignored and is the correct place for secrets.
# .env.docker is tracked, so keep this file as a safe template only.

# Build
WITH_CUDA=true
CUDA_ARCHS=120

# Ports (host -> container)
MCP_PORT=8001
SERVICE_PORT=8642

# Paths
MODELS_PATH=./models
LLM_BAWT_MODEL_CACHE_DIR=~/.cache/llm-bawt/models
HF_HOME=~/.cache/huggingface

# Core
LLM_BAWT_DEFAULT_BOT=nova
LLM_BAWT_DEFAULT_MODEL_ALIAS=grok-4-fast
LLM_BAWT_DEFAULT_USER=nick
LLM_BAWT_USE_SERVICE=true
LLM_BAWT_SERVICE_HOST=0.0.0.0
LLM_BAWT_SERVICE_PORT=8642
LLM_BAWT_MCP_SERVER_URL=http://127.0.0.1:8001

# Home Assistant integration
# Preferred: native MCP direct to Home Assistant's built-in /api/mcp endpoint.
# Legacy custom HA MCP is kept only for backward compatibility and should stay
# disabled unless you run a separate custom HA MCP server.
LLM_BAWT_HA_MCP_ENABLED=false
# Legacy custom HA MCP base URL (ignored unless LLM_BAWT_HA_MCP_ENABLED=true)
LLM_BAWT_HA_MCP_URL=http://127.0.0.1:3000
LLM_BAWT_HA_MCP_TIMEOUT=10
# Optional bearer token for the legacy custom HA MCP server only
LLM_BAWT_HA_MCP_AUTH_TOKEN=
# Native HA MCP (preferred)
# Example: http://home-assistant.local:8123/api/mcp
# When both URL and token are set, this takes priority over the legacy server above
LLM_BAWT_HA_NATIVE_MCP_URL=
# Home Assistant long-lived access token for native MCP auth
LLM_BAWT_HA_NATIVE_MCP_TOKEN=
# Comma-separated native HA tool names to exclude
LLM_BAWT_HA_MCP_TOOL_EXCLUDE=GetDateTime,HassCancelAllTimers,HassBroadcast
LLM_BAWT_LOG_DIR=.logs
LLM_BAWT_LOG_PREFIX=docker
LLM_BAWT_DEBUG_TURN_LOG=false
LLM_BAWT_HISTORY_DURATION_SECONDS=1800
LLM_BAWT_HISTORY_RELOAD_TTL_SECONDS=2
LLM_BAWT_MAX_OUTPUT_TOKENS=4096

# Llama.cpp (optional)
LLM_BAWT_LLAMA_CPP_N_CTX=8192
LLM_BAWT_LLAMA_CPP_N_GPU_LAYERS=-1
LLM_BAWT_LLAMA_CPP_N_BATCH=1024
LLM_BAWT_LLAMA_CPP_FLASH_ATTN=true

# PostgreSQL
LLM_BAWT_POSTGRES_HOST=localhost
LLM_BAWT_POSTGRES_PORT=5432
LLM_BAWT_POSTGRES_USER=llm_bawt
LLM_BAWT_POSTGRES_PASSWORD=
LLM_BAWT_POSTGRES_DATABASE=llm_bawt

# xAI (Grok)
LLM_BAWT_XAI_API_KEY=

# Search
LLM_BAWT_SEARCH_PROVIDER=duckduckgo
LLM_BAWT_TAVILY_API_KEY=
LLM_BAWT_BRAVE_API_KEY=
LLM_BAWT_REDDIT_CLIENT_ID=
LLM_BAWT_REDDIT_CLIENT_SECRET=
LLM_BAWT_REDDIT_USER_AGENT=llm-bawt/0.1

# OpenClaw Bridge — unprefixed vars for the bridge container
# (must match the LLM_BAWT_POSTGRES_* values above)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
OPENCLAW_WS_URL=
OPENCLAW_GATEWAY_TOKEN=

# Redis URL for bridge event transport (required for OpenClaw integration)
# The main app uses this to send commands and receive events from the bridge
LLM_BAWT_REDIS_URL=redis://redis:6379/0
# Bridge-specific settings (only used by the openclaw-bridge container)
OPENCLAW_BRIDGE_LOG_LEVEL=INFO
# Ingest filters — comma-separated. Merged with built-in defaults.
# Regex patterns: user messages matching any pattern are silently dropped.
OPENCLAW_INGEST_DROP_PATTERNS=
# Additional gateway event names to drop (built-in: health,tick,heartbeat,presence,shutdown)
OPENCLAW_INGEST_DROP_EVENTS=
# Additional top-level msg types to drop (built-in: ping,pong,heartbeat)
OPENCLAW_INGEST_DROP_MSG_TYPES=

# Claude Code bridge (uses Agent SDK + your Max subscription)
# Generate with: claude setup-token (or extract from ~/.claude/.credentials.json)
CLAUDE_CODE_OAUTH_TOKEN=
# No CLAUDE_CODE_MODEL — there is no default model.  The bridge requires
# every request to carry its model, resolved from the bot's default_model
# catalog entry (type=claude-code), and raises if it's missing.
# See src/claude_code_bridge/bridge.py.
CLAUDE_CODE_CWD=/home/bridge/dev
CLAUDE_CODE_SESSION_PREFIXES=claude-code:
CLAUDE_CODE_BRIDGE_LOG_LEVEL=INFO

# NewsAPI (newsapi.org)
LLM_BAWT_NEWSAPI_API_KEY=

# Providers
OPENAI_API_KEY=
XAI_API_KEY=
ANTHROPIC_API_KEY=
HF_TOKEN=

# Nextcloud Talk (optional)
LLM_BAWT_NEXTCLOUD_URL=https://nextcloud.example.com
LLM_BAWT_NEXTCLOUD_BOT_SECRET=
LLM_BAWT_TALK_PROVISIONER_URL=http://localhost:8790
LLM_BAWT_TALK_PROVISIONER_TOKEN=

# Transformers / HF behavior
HF_HUB_DISABLE_PROGRESS_BARS=1
TRANSFORMERS_NO_ADVISORY_WARNINGS=1
TRANSFORMERS_VERBOSITY=error
TOKENIZERS_PARALLELISM=false

# ============================================================================
# Media storage backend (TASK-266)
# ----------------------------------------------------------------------------
# MediaStore (chat upload variants) and MediaStorage (generated video /
# image outputs) share a pluggable backend. Default is local-filesystem
# (the legacy NFS bind mounts in docker-compose.yml are still authoritative);
# flip to ``s3`` once Garage is provisioned and the existing blobs have been
# rclone'd across — see TASK-266 spec for the cutover runbook.
#
# Garage runs on Unraid (container ``garage-s3-simple``, IP 10.0.2.38).
# Bucket per app: ``llmbawt-media`` (this repo) / ``bawthub-uploads`` (bawthub).
# Access keys are stored in Vaultwarden as ``garage/llmbawt-app-s3-key`` —
# fetch with ``bw-secret garage/llmbawt-app-s3-key --user`` / ``--pass``.
# ============================================================================

LLM_BAWT_STORAGE_BACKEND=fs
LLM_BAWT_S3_ENDPOINT=http://10.0.2.38:9000
LLM_BAWT_S3_REGION=garage
LLM_BAWT_S3_BUCKET=llmbawt-media
LLM_BAWT_S3_ACCESS_KEY=
LLM_BAWT_S3_SECRET_KEY=
# Cutover safety net: when ``true``, S3 GETs that 404 retry from the FS
# bind mount. Use during the migration window, then flip back to ``false``
# and (eventually) drop the NFS mounts.
LLM_BAWT_S3_FALLBACK_FS=false
